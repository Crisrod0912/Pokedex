@model Pokedex.Models.UsuariosModel

<link href="~/css/crudusuarios.css" rel="stylesheet" />

<div class="pokedex-container">
    
    <h1>Editar Usuario</h1>
    
    <form asp-action="Editar" method="post">
        <input type="hidden" asp-for="IdUsuario" />
        <div class="form-group">
            <label asp-for="Usuario"></label>
            <input asp-for="Usuario" class="form-control" />
            <span asp-validation-for="Usuario" class="text-danger"></span>
        </div>
        
        <div class="form-group">
            <label asp-for="NombreUsuario"></label>
            <input asp-for="NombreUsuario" class="form-control" />
            <span asp-validation-for="NombreUsuario" class="text-danger"></span>
        </div>
        
        <div class="form-group">
            <label asp-for="Contrasenna"></label>
            <input asp-for="Contrasenna" class="form-control" />
            <span asp-validation-for="Contrasenna" class="text-danger"></span>
        </div>
        
        <div class="form-group">
            <label asp-for="Rol"></label>
            <select asp-for="Rol" class="form-control">
                <option value="Admin">Admin</option>
                <option value="Entrenador">Entrenador</option>
                <option value="Enfermera">Enfermera</option>
            </select>
            <span asp-validation-for="Rol" class="text-danger"></span>
        </div>
        
        <button type="submit" class="btn btn-primary">Guardar Cambios</button>
        
        <a asp-action="Usuarios" class="btn btn-secondary">Cancelar</a>
    </form>

</div>
